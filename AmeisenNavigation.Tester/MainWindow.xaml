<Window x:Class="AmeisenNavigation.Tester.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AmeisenNavigation.Tester.Controls"
        Title="AmeisenNavigation Tester" Height="750" Width="1250"
        MinHeight="600" MinWidth="1000"
        Loaded="Window_Loaded" Closing="Window_Closing">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="400"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="300" MinWidth="250" MaxWidth="450"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Map Canvas -->
        <Border Grid.Column="0" Grid.Row="0"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <controls:MapCanvas x:Name="MapCanvas" ClipToBounds="True"/>

                <!-- Loading overlay -->
                <Grid x:Name="LoadingOverlay" Visibility="Collapsed"
                      Background="#CC000000">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Width="320">
                        <TextBlock x:Name="TxtLoadingTitle" Text="Loading..."
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource ForegroundBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <ProgressBar x:Name="LoadingProgress" Height="6"
                                     IsIndeterminate="True" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtLoadingStatus" Text=""
                                   FontSize="12"
                                   Foreground="{StaticResource ForegroundDimBrush}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Grid.Row="0"
                      Width="5" HorizontalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext"
                      Cursor="SizeWE"/>

        <!-- Control Panel -->
        <ScrollViewer Grid.Column="2" Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="{StaticResource BackgroundDark}">
            <StackPanel Margin="8">

                <!-- Data Source -->
                <GroupBox Header="Data Source" Margin="0,0,0,6">
                    <DockPanel>
                        <Button x:Name="BtnBrowseData" Content="Browse..."
                                DockPanel.Dock="Right" Width="68" Margin="4,0,0,0"
                                Click="BtnBrowseData_Click"
                                ToolTip="Select the WoW Data directory containing MPQ archives"/>
                        <TextBox x:Name="TxtDataDir" IsReadOnly="True"
                                 Text="Select WoW Data directory..."
                                 Foreground="{StaticResource ForegroundDimBrush}"/>
                    </DockPanel>
                </GroupBox>

                <!-- Navmesh Overlay -->
                <GroupBox Header="Navmesh Overlay" Margin="0,0,0,6">
                    <StackPanel>
                        <DockPanel>
                            <Button x:Name="BtnBrowseMeshes" Content="Browse..."
                                    DockPanel.Dock="Right" Width="68" Margin="4,0,0,0"
                                    Click="BtnBrowseMeshes_Click"
                                    ToolTip="Select directory containing .anp navmesh files"/>
                            <TextBox x:Name="TxtMeshesDir" IsReadOnly="True"
                                     Text="Select meshes directory..."
                                     Foreground="{StaticResource ForegroundDimBrush}"/>
                        </DockPanel>
                        <CheckBox x:Name="ChkShowAreas" Content="Show Area Overlay"
                                  Margin="0,4,0,0" Click="ChkShowAreas_Click"/>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock x:Name="lblOverlayOpacity" Text="Opacity: 40%" Width="100"
                                       VerticalAlignment="Center"/>
                            <Slider x:Name="sldOverlayOpacity" Minimum="10" Maximum="100" Value="40"
                                    TickFrequency="5" IsSnapToTickEnabled="True"
                                    ValueChanged="SldOverlayOpacity_ValueChanged"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <!-- Connection -->
                <GroupBox Header="Connection" Margin="0,0,0,6">
                    <StackPanel>
                        <DockPanel>
                            <Label Content="Map" Width="40"/>
                            <ComboBox x:Name="ComboBoxMap"
                                      DisplayMemberPath="Value" SelectedValuePath="Key"
                                      SelectionChanged="ComboBoxMap_SelectionChanged"/>
                        </DockPanel>
                        <DockPanel Margin="0,4,0,0">
                            <Button x:Name="ButtonRun" Content="Get Path"
                                    DockPanel.Dock="Right" Width="80"
                                    Click="ButtonRun_Click"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="StatusIndicator" Width="10" Height="10"
                                         Fill="#ff3333" Margin="4,0,6,0"/>
                                <TextBlock x:Name="TxtConnectionStatus" Text="Disconnected"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <!-- Coordinates -->
                <GroupBox Header="Coordinates" Margin="0,0,0,6">
                    <StackPanel>
                        <TextBlock Text="Left-click to set Start, Right-click to set End"
                                   Foreground="{StaticResource ForegroundDimBrush}"
                                   FontSize="10" Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="26"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Start"
                                       VerticalAlignment="Center" Foreground="#00ff00"/>
                            <TextBox x:Name="TextBoxStartX" Grid.Row="0" Grid.Column="1" Margin="2,0"/>
                            <TextBox x:Name="TextBoxStartY" Grid.Row="0" Grid.Column="2" Margin="2,0"/>
                            <TextBox x:Name="TextBoxStartZ" Grid.Row="0" Grid.Column="3" Margin="2,0"/>
                            <Button x:Name="ButtonRandomStart" Grid.Row="0" Grid.Column="4"
                                    Content="R" Padding="0" FontSize="10"
                                    Click="ButtonRandomStart_Click"
                                    ToolTip="Random start point"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="End"
                                       VerticalAlignment="Center" Foreground="#ff3333"/>
                            <TextBox x:Name="TextBoxEndX" Grid.Row="2" Grid.Column="1" Margin="2,0"/>
                            <TextBox x:Name="TextBoxEndY" Grid.Row="2" Grid.Column="2" Margin="2,0"/>
                            <TextBox x:Name="TextBoxEndZ" Grid.Row="2" Grid.Column="3" Margin="2,0"/>
                            <Button x:Name="ButtonRandomEnd" Grid.Row="2" Grid.Column="4"
                                    Content="R" Padding="0" FontSize="10"
                                    Click="ButtonRandomEnd_Click"
                                    ToolTip="Random end point"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Path Options -->
                <GroupBox Header="Path Options" Margin="0,0,0,6">
                    <StackPanel>
                        <TextBlock Text="Type" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <WrapPanel>
                            <RadioButton x:Name="rbPathTypeStraight" Content="Straight"
                                         IsChecked="True" GroupName="pathType"
                                         Margin="0,0,12,0" Click="PathOption_Changed"/>
                            <RadioButton x:Name="rbPathTypeRandom" Content="Random"
                                         GroupName="pathType" Click="PathOption_Changed"/>
                        </WrapPanel>

                        <TextBlock Text="Smoothing" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <WrapPanel>
                            <CheckBox x:Name="rbPathFlagsChaikin" Content="Chaikin"
                                      Margin="0,0,12,0" Click="PathOption_Changed"
                                      Checked="RbPathFlagsChaikin_Checked"/>
                            <CheckBox x:Name="rbPathFlagsCatmullRom" Content="Catmull-Rom"
                                      Margin="0,0,12,0" Click="PathOption_Changed"
                                      Checked="RbPathFlagsCatmullRom_Checked"/>
                            <CheckBox x:Name="rbPathFlagsBezier" Content="Bezier"
                                      Margin="0,0,12,0" Click="PathOption_Changed"
                                      Checked="RbPathFlagsBezier_Checked"/>
                        </WrapPanel>

                        <TextBlock Text="Validation" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <WrapPanel>
                            <CheckBox x:Name="rbPathFlagsValidateCpop" Content="CPOP"
                                      Margin="0,0,12,0" Click="PathOption_Changed"
                                      Checked="RbPathFlagsValidateCpop_Checked"
                                      ToolTip="Closest Point On Poly — snap each waypoint to the nearest valid polygon"/>
                            <CheckBox x:Name="rbPathFlagsValidateMas" Content="MAS"
                                      Margin="0,0,12,0" Click="PathOption_Changed"
                                      Checked="RbPathFlagsValidateMas_Checked"
                                      ToolTip="Move Along Surface — slide each waypoint along the navmesh surface"/>
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>

                <!-- Filter Config -->
                <GroupBox Header="Filter Config" Margin="0,0,0,6">
                    <StackPanel>
                        <TextBlock Text="Client State" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <WrapPanel>
                            <RadioButton x:Name="rbClientStateNormal" Content="Normal"
                                         IsChecked="True" GroupName="clientState"
                                         Margin="0,0,10,4" Click="RbClientState_Click"/>
                            <RadioButton x:Name="rbClientStateDead" Content="Dead"
                                         GroupName="clientState"
                                         Margin="0,0,10,4" Click="RbClientState_Click"/>
                            <RadioButton x:Name="rbClientStateNormalAlly" Content="Alliance"
                                         GroupName="clientState"
                                         Margin="0,0,10,4" Click="RbClientState_Click"/>
                            <RadioButton x:Name="rbClientStateNormalHorde" Content="Horde"
                                         GroupName="clientState"
                                         Margin="0,0,10,4" Click="RbClientState_Click"/>
                        </WrapPanel>

                        <TextBlock Text="Area Costs" FontWeight="SemiBold" Margin="0,6,0,2"/>
                        <DockPanel Margin="0,2,0,0">
                            <TextBlock x:Name="lblCostGround" Text="Ground: 1.0" Width="100"
                                       VerticalAlignment="Center"/>
                            <Slider x:Name="sldCostGround" Minimum="1" Maximum="25" Value="1"
                                    ValueChanged="SldCostGround_ValueChanged"/>
                        </DockPanel>
                        <DockPanel Margin="0,2,0,0">
                            <TextBlock x:Name="lblCostRoad" Text="Road: 0.75" Width="100"
                                       VerticalAlignment="Center"/>
                            <Slider x:Name="sldCostRoad" Minimum="0.1" Maximum="5" Value="0.75"
                                    TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    ValueChanged="SldCostRoad_ValueChanged"/>
                        </DockPanel>
                        <DockPanel Margin="0,2,0,0">
                            <TextBlock x:Name="lblCostWater" Text="Water: 1.3" Width="100"
                                       VerticalAlignment="Center"/>
                            <Slider x:Name="sldCostWater" Minimum="1" Maximum="25" Value="1.3"
                                    ValueChanged="SldCostWater_ValueChanged"/>
                        </DockPanel>
                        <DockPanel Margin="0,2,0,0">
                            <TextBlock x:Name="lblCostBadLiquid" Text="Magma/Slime: 4.0" Width="100"
                                       VerticalAlignment="Center"/>
                            <Slider x:Name="sldCostBadLiquid" Minimum="1" Maximum="25" Value="4"
                                    ValueChanged="SldCostBadLiquid_ValueChanged"/>
                        </DockPanel>

                        <TextBlock Text="Faction Danger" FontWeight="SemiBold" Margin="0,6,0,2"/>
                        <DockPanel Margin="0,2,0,0">
                            <TextBlock x:Name="lblFactionDanger" Text="Faction: 3.0" Width="100"
                                       VerticalAlignment="Center"/>
                            <Slider x:Name="sldFactionDanger" Minimum="1" Maximum="25" Value="3"
                                    ValueChanged="SldFactionDanger_ValueChanged"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <!-- Stats -->
                <GroupBox Header="Stats" Margin="0,0,0,6">
                    <StackPanel>
                        <TextBlock x:Name="lblPointCount" Text="Points: 0"/>
                        <TextBlock x:Name="lblDistance" Text="0 m"/>
                        <TextBlock x:Name="lblTime" Text="0 ms"/>
                    </StackPanel>
                </GroupBox>

                <!-- Path Points -->
                <GroupBox Header="Path Points" Margin="0,0,0,6">
                    <ListBox x:Name="PointList" MaxHeight="200"
                             FontFamily="Consolas" FontSize="11"/>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <StatusBar Grid.Row="1" Grid.ColumnSpan="3">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatusConnection" Text="Disconnected" Foreground="#ff3333"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="TxtStatusPath" Text="" Foreground="{StaticResource ForegroundDimBrush}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="TxtStatusCoords" Text="X: 0.0  Y: 0.0"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="TxtStatusTile" Text="Tile: -, -"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="TxtStatusZoom" Text="Zoom: 1.0x"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
